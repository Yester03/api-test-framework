  "item": [
    {
      "name": "get /post/1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Content-Type is JSON\", function () {\r",
              "  pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "pm.test(\"Post schema has required fields\", function () {\r",
              "  const data = pm.response.json();\r",
              "  pm.expect(data).to.have.property(\"userId\");\r",
              "  pm.expect(data).to.have.property(\"id\");\r",
              "  pm.expect(data).to.have.property(\"title\");\r",
              "  pm.expect(data).to.have.property(\"body\");\r",
              "  pm.expect(data.title).to.be.a(\"string\");\r",
              "  pm.expect(data.body).to.be.a(\"string\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts",
            "1"
          ]
        }
      },
      "response": []
